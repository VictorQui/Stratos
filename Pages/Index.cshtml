@page
@model ProyectoWebIDP.Pages.IndexModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
<h1>Hola mundo</h1>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Evaluación de Liderazgo</title>
    <style>
        /* Estilos generales y fondo degradado */
        body, html {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            background: linear-gradient(135deg, #e0f2fe 0%, #ecfdf5 50%, #d1fae5 100%);
            color: #1e293b;
        }

        .container {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 40px 20px;
            box-sizing: border-box;
            min-height: 100vh;
        }

        /* Encabezado y Pie de página */
        .header, .footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            width: 100%;
            max-width: 850px;
        }

        .header {
            margin-bottom: 30px;
        }

        .footer {
            margin-top: 30px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .logo-icon {
            font-size: 28px;
        }

        .logo-text h1 {
            margin: 0;
            font-size: 22px;
            color: #0f172a;
        }

        .logo-text p {
            margin: 0;
            font-size: 14px;
            color: #059669;
        }

        /* Tarjeta Glassmorphism */
        .glass-card {
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.6);
            border-radius: 20px;
            padding: 40px 50px;
            width: 100%;
            max-width: 850px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            box-sizing: border-box;
        }

        /* --- Título y encabezado centrados --- */
        .card-header {
            display: flex;
            flex-direction: column; 
            align-items: center; 
            text-align: center; 
            margin-bottom: 35px;
            gap: 15px; 
        }

        .card-title h2 {
            margin: 0;
            font-size: 32px;
            color: #1e293b;
            line-height: 1.2;
        }

        .card-title p {
            font-size: 18px;
            color: #334155;
            margin-top: 10px;
        }

        .illustration {
            font-size: 60px;
            line-height: 1;
        }

        /* Cuadrícula del formulario */
        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 25px;
            margin-bottom: 35px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

            .form-group label {
                font-weight: 600;
                font-size: 14px;
                color: #1e293b;
            }

            /* --- Estilos compartidos para input y el nuevo select --- */
            .form-group input,
            .form-group select {
                padding: 14px 16px;
                border: none;
                border-radius: 8px;
                font-size: 15px;
                outline: none;
                background-color: #ffffff;
                box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
                transition: box-shadow 0.2s;
                font-family: inherit;
                color: #1e293b;
                width: 100%;
                box-sizing: border-box;
            }

            /* --- Ajustes específicos para el desplegable (select) --- */
            .form-group select {
                cursor: pointer;
                appearance: none; 
                background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23334155' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
                background-repeat: no-repeat;
                background-position: right 15px center;
                background-size: 16px;
            }

                .form-group input:focus,
                .form-group select:focus {
                    box-shadow: inset 0 2px 4px rgba(0,0,0,0.02), 0 0 0 2px #6366f1;
                }

        /* Botón */
        .button-container {
            text-align: center;
        }

        .submit-btn {
            background: linear-gradient(90deg, #60a5fa 0%, #818cf8 100%);
            color: white;
            border: none;
            padding: 16px 45px;
            border-radius: 30px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(129, 140, 248, 0.4);
            transition: transform 0.2s, box-shadow 0.2s;
        }

            .submit-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(129, 140, 248, 0.6);
            }

        /* Enlace del footer */
        .footer-link {
            font-size: 14px;
            color: #475569;
        }

            .footer-link a {
                color: #60a5fa;
                text-decoration: none;
                font-weight: 600;
            }

        .alert-error {
            background-color: rgba(254, 226, 226, 0.9);
            color: #991b1b;
            padding: 14px;
            border-radius: 8px;
            margin-bottom: 25px;
            border-left: 5px solid #ef4444;
            font-weight: 600;
            text-align: center;
            font-size: 15px;
            width: 100%;
            box-sizing: border-box;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
        }
        @@media (max-width: 650px) {
            .form-grid {
                grid-template-columns: 1fr;
            }

            .header, .footer {
                flex-direction: column;
                gap: 20px;
                text-align: center;
            }

            .glass-card {
                padding: 30px 20px;
            }
        }
    </style>
</head>
<body>
    <div class="container">

        <header class="header">
            <div class="logo">
                <span class="logo-icon">🧭</span>
                <div class="logo-text">
                    <h1>Liderazgo</h1>
                    <p>Personal en Línea</p>
                </div>
            </div>
        </header>

        <main class="glass-card">

            <div class="card-header">
                <div class="card-title">
                    <h2>Evaluación de Liderazgo<br>Personal en Línea 🧭</h2>
                    <p>Ingresa tus Datos para Comenzar</p>
                </div>
                <div class="illustration">
                    🧍‍♂️📈
                </div>
            </div>

            <form method="POST">
                
                @if (ViewData["ErrorCorreo"] != null)
                {
                    <div class="alert-error">
                        ⚠️ @ViewData["ErrorCorreo"]
                    </div>
                }

                <div class="form-grid">
                    <div class="form-group">
                        <label for="nombre">Nombre Completo</label>
                        <input type="text" id="nombre" name="nombre" placeholder="Tu nombre" required>
                    </div>

                    <div class="form-group">
                        <label for="correo">Correo Electrónico</label>
                        <input type="email" id="correo" name="correo" placeholder="tu@correo.com" required>
                    </div>

                    
                    <div class="form-group">
                        <label for="semestre">Semestre Cursado</label>
                        <select id="semestre" name="semestre" required>
                            <option value="" disabled selected>Selecciona tu semestre</option>
                            <option value="1">1er Semestre</option>
                            <option value="2">2do Semestre</option>
                            <option value="3">3er Semestre</option>
                            <option value="4">4to Semestre</option>
                            <option value="5">5to Semestre</option>
                            <option value="6">6to Semestre</option>
                            <option value="7">7mo Semestre</option>
                            <option value="8">8vo Semestre</option>
                            <option value="9">9no Semestre</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="carrera">Carrera</label>
                        <input type="text" id="carrera" name="carrera" placeholder="Ej. TICS" required>
                    </div>
                </div>

                <div class="button-container">
                    <button type="submit" class="submit-btn">COMENZAR EVALUACIÓN AHORA</button>
                </div>
            </form>
        </main>

        <footer class="footer">
            <div class="logo">
                <span class="logo-icon">🧭</span>
                <div class="logo-text">
                    <h1>Todos los derechos reservados</h1>
                    <p>Realizado por Equipo Stratos</p>
                </div>
            </div>
            <div class="footer-link">
                ¿Ya tienes resultados? <a href="/Consultar">Consulte aquí</a>
            </div>
        </footer>

    </div>
</body>
</html>
