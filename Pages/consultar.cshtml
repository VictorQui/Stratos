@page
@model ProyectoWebIDP.Pages.ConsultarModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Consultar Resultados - Liderazgo</title>
    <style>
        /* Mismos estilos base de tu Index */
        body, html {
            margin: 0; padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            background: linear-gradient(135deg, #e0f2fe 0%, #ecfdf5 50%, #d1fae5 100%);
            color: #1e293b;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.6);
            border-radius: 20px;
            padding: 40px 50px;
            width: 100%;
            max-width: 500px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            text-align: center;
        }

        .card-title h2 { margin: 0 0 10px 0; font-size: 28px; color: #1e293b; }
        .card-title p { font-size: 16px; color: #334155; margin-bottom: 30px; }

        .form-group { text-align: left; margin-bottom: 25px; }
        .form-group label { font-weight: 600; font-size: 14px; color: #1e293b; display: block; margin-bottom: 8px; }
        .form-group input {
            width: 100%; padding: 14px 16px; border: none; border-radius: 8px;
            font-size: 15px; outline: none; background-color: #ffffff;
            box-shadow: inset 0 2px 4px rgba(0,0,0,0.02); box-sizing: border-box;
        }
        .form-group input:focus { box-shadow: inset 0 2px 4px rgba(0,0,0,0.02), 0 0 0 2px #6366f1; }

        .submit-btn {
            background: linear-gradient(90deg, #60a5fa 0%, #818cf8 100%);
            color: white; border: none; padding: 14px 30px; border-radius: 30px;
            font-size: 16px; font-weight: 600; cursor: pointer; width: 100%;
            box-shadow: 0 4px 15px rgba(129, 140, 248, 0.4); transition: transform 0.2s;
        }
        .submit-btn:hover { transform: translateY(-2px); }

        .alert-error {
            background-color: rgba(254, 226, 226, 0.9); color: #991b1b;
            padding: 14px; border-radius: 8px; margin-bottom: 20px;
            border-left: 5px solid #ef4444; font-weight: 600; font-size: 14px;
        }

        .btn-volver {
            display: inline-block; margin-top: 20px; color: #60a5fa;
            text-decoration: none; font-weight: 600; font-size: 14px;
        }
    </style>
</head>
<body>
    <div class="glass-card">
        <div class="card-title">
            <h2>🔍 Consultar Resultados</h2>
            <p>Ingresa tu correo para ver tu evaluación</p>
        </div>

        <form method="POST">
            @if (ViewData["ErrorConsulta"] != null)
            {
                <div class="alert-error">
                    ⚠️ @ViewData["ErrorConsulta"]
                </div>
            }

            <div class="form-group">
                <label for="correo">Correo Electrónico registrado</label>
                <input type="email" id="correo" name="Correo" placeholder="tu@correo.com" required>
            </div>

            <button type="submit" class="submit-btn">BUSCAR RESULTADOS</button>
        </form>

        <a href="/" class="btn-volver">← Volver al inicio</a>
    </div>
</body>
</html>