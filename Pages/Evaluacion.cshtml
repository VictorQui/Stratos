<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Test de Liderazgo</title>
    <style>
        body, html {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f8fafc;
            color: #1e293b;
        }

        /* BARRA DE PROGRESO FIJA */
        .progress-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            background: white;
            padding: 15px 20px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 20px;
            box-sizing: border-box;
        }

        .progress-bar-bg {
            width: 100%;
            max-width: 600px;
            height: 12px;
            background-color: #e2e8f0;
            border-radius: 10px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #60a5fa 0%, #34d399 100%);
            width: 0%;
            transition: width 0.4s ease;
        }

        .progress-text {
            font-weight: bold;
            color: #475569;
            min-width: 50px;
        }

        /* CONTENEDOR PRINCIPAL */
        .main-content {
            padding: 100px 20px 40px 20px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .instructions {
            text-align: center;
            margin-bottom: 40px;
        }

        /* GRID DE LOS GRUPOS */
        .test-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 25px;
        }

        .group-card {
            background: white;
            border-radius: 12px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.03);
            border-top: 5px solid #8b5cf6;
            padding: 15px;
            transition: border-color 0.3s ease;
        }

        .group-number {
            font-weight: bold;
            color: #8b5cf6;
            margin-bottom: 10px;
            font-size: 18px;
        }

        /* TABLA DENTRO DE CADA TARJETA */
        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            font-size: 12px;
            color: white;
            background-color: #1e293b;
            padding: 5px;
            text-align: center;
        }

        th:first-child {
            background: transparent;
            color: #1e293b;
            text-align: left;
        }

        td {
            padding: 8px 5px;
            border-bottom: 1px solid #f1f5f9;
            font-size: 14px;
        }

        td:not(:first-child) {
            text-align: center;
        }

        input[type="radio"] {
            transform: scale(1.3);
            cursor: pointer;
        }

        /* BOTÓN DE COMPLETADO */
        .submit-section {
            text-align: center;
            margin-top: 50px;
        }

        .btn-completar {
            background: #8b5cf6;
            color: white;
            border: none;
            padding: 15px 40px;
            font-size: 18px;
            font-weight: bold;
            border-radius: 30px;
            cursor: pointer;
            opacity: 0.5;
            pointer-events: none;
            transition: all 0.3s;
        }

        .btn-completar.active {
            opacity: 1;
            pointer-events: all;
            box-shadow: 0 5px 15px rgba(139, 92, 246, 0.4);
        }

        .btn-completar.active:hover {
            transform: translateY(-2px);
        }
    </style>
</head>
<body>

    <div class="progress-container">
        <span>Progreso:</span>
        <div class="progress-bar-bg">
            <div class="progress-fill" id="progressFill"></div>
        </div>
        <span class="progress-text" id="progressText">0%</span>
    </div>

    <div class="main-content">
        <div class="instructions">
            <h2>Evaluación DISC</h2>
            <p>Escoja <strong>una</strong> palabra en <strong>MÁS</strong> y <strong>una</strong> palabra en <strong>MENOS</strong> en cada uno de los grupos.</p>
        </div>

        <form method="POST" id="formDISC">
            <input type="hidden" asp-for="UsuarioId" />
            
            <input type="hidden" id="ZMas" name="ZMas" value="0">
            <input type="hidden" id="EstrellaMas" name="EstrellaMas" value="0">
            <input type="hidden" id="CuadradoMas" name="CuadradoMas" value="0">
            <input type="hidden" id="TrianguloMas" name="TrianguloMas" value="0">

            <input type="hidden" id="ZMenos" name="ZMenos" value="0">
            <input type="hidden" id="EstrellaMenos" name="EstrellaMenos" value="0">
            <input type="hidden" id="CuadradoMenos" name="CuadradoMenos" value="0">
            <input type="hidden" id="TrianguloMenos" name="TrianguloMenos" value="0">

            <div class="test-grid">
                @for (int i = 0; i < grupos.Count; i++)
                {
                    <div class="group-card" id="group-@(i)">
                        <div class="group-number">@(i + 1)</div>
                        <table>
                            <tr>
                                <th>Palabra</th>
                                <th>MÁS</th>
                                <th>MENOS</th>
                            </tr>
                            @for (int j = 0; j < 4; j++)
                            {
                                // Aquí separamos la palabra del símbolo para que el HTML sepa qué imprimir
                                var datos = grupos[i][j].Split('|');
                                var palabra = datos[0];
                                var simbolo = datos.Length > 1 ? datos[1] : "";

                                <tr>
                                    <td>@palabra</td>
                                    <td>
                                        <input type="radio" class="radio-btn" name="mas_@(i)" value="@simbolo" data-grupo="@i" data-tipo="mas" data-fila="@j">
                                    </td>
                                    <td>
                                        <input type="radio" class="radio-btn" name="menos_@(i)" value="@simbolo" data-grupo="@i" data-tipo="menos" data-fila="@j">
                                    </td>
                                </tr>
                            }
                        </table>
                    </div>
                }
            </div>

            <div class="submit-section">
                <button type="submit" class="btn-completar" id="btnSubmit">COMPLETADO</button>
            </div>
            @if (!string.IsNullOrEmpty(Model.ResultadoFinal))
            {
                <div class="alert alert-info">
                    @Model.ResultadoFinal
                </div>
            }
        </form>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {

            const totalGrupos = @grupos.Count;
            const radios = document.querySelectorAll('.radio-btn');
            const progressFill = document.getElementById('progressFill');
            const progressText = document.getElementById('progressText');
            const btnSubmit = document.getElementById('btnSubmit');
            const formDISC = document.getElementById('formDISC'); // Nuevo

            btnSubmit.disabled = true;

            radios.forEach(radio => {
                radio.addEventListener('change', function () {
                    const grupoId = this.getAttribute('data-grupo');
                    const tipo = this.getAttribute('data-tipo');
                    const fila = this.getAttribute('data-fila');

                    const tipoOpuesto = tipo === 'mas' ? 'menos' : 'mas';
                    const radioOpuesto = document.querySelector(`input[name="${tipoOpuesto}_${grupoId}"][data-fila="${fila}"]`);

                    if (radioOpuesto && radioOpuesto.checked) {
                        radioOpuesto.checked = false;
                    }

                    calcularProgreso();
                });
            });

            function calcularProgreso() {
                let gruposCompletos = 0;

                for (let i = 0; i < totalGrupos; i++) {
                    const tieneMas = document.querySelector(`input[name="mas_${i}"]:checked`);
                    const tieneMenos = document.querySelector(`input[name="menos_${i}"]:checked`);
                    const tarjeta = document.getElementById(`group-${i}`);

                    if (tieneMas && tieneMenos) {
                        gruposCompletos++;
                        if(tarjeta) tarjeta.style.borderTopColor = '#34d399'; 
                    } else {
                        if(tarjeta) tarjeta.style.borderTopColor = '#8b5cf6'; 
                    }
                }

                const porcentaje = Math.round((gruposCompletos / totalGrupos) * 100);

                progressFill.style.width = porcentaje + '%';
                progressText.innerText = porcentaje + '%';

                if (porcentaje === 100) {
                    btnSubmit.classList.add('active');
                    btnSubmit.disabled = false;
                } else {
                    btnSubmit.classList.remove('active');
                    btnSubmit.disabled = true;
                }
            }

            calcularProgreso();

            // LÓGICA DE SUMA Y ENVÍO
            formDISC.addEventListener('submit', function (e) {
                e.preventDefault(); // Pausar envío para sumar

                let zMas = 0, estrellaMas = 0, cuadradoMas = 0, trianguloMas = 0;
                let zMenos = 0, estrellaMenos = 0, cuadradoMenos = 0, trianguloMenos = 0;

                // Sumar los de la columna MÁS
                document.querySelectorAll('input[data-tipo="mas"]:checked').forEach(radio => {
                    if (radio.value === 'Z') zMas++;
                    if (radio.value === 'Estrella') estrellaMas++;
                    if (radio.value === 'Cuadrado') cuadradoMas++;
                    if (radio.value === 'Triangulo') trianguloMas++;
                });

                // Sumar los de la columna MENOS
                document.querySelectorAll('input[data-tipo="menos"]:checked').forEach(radio => {
                    if (radio.value === 'Z') zMenos++;
                    if (radio.value === 'Estrella') estrellaMenos++;
                    if (radio.value === 'Cuadrado') cuadradoMenos++;
                    if (radio.value === 'Triangulo') trianguloMenos++;
                });

                // Pasar los resultados a los inputs ocultos
                document.getElementById('ZMas').value = zMas;
                document.getElementById('EstrellaMas').value = estrellaMas;
                document.getElementById('CuadradoMas').value = cuadradoMas;
                document.getElementById('TrianguloMas').value = trianguloMas;

                document.getElementById('ZMenos').value = zMenos;
                document.getElementById('EstrellaMenos').value = estrellaMenos;
                document.getElementById('CuadradoMenos').value = cuadradoMenos;
                document.getElementById('TrianguloMenos').value = trianguloMenos;

                // Reanudar el envío a C#
                formDISC.submit();
            });
        });
    </script>
</body>
</html>