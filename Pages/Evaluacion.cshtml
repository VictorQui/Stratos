        new string[] { "Competitivo/a|Z", "Considerado/a|Triangulo", "Alegre|Cuadrado", "Sagaz|Estrella" }, // Grupo 13
        new string[] { "Meticuloso/a|Estrella", "Obediente|Triangulo", "Ideas Firmes|Z", "Alentador/a|Cuadrado" }, // Grupo 14
